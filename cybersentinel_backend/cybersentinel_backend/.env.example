# ================================================================
#  CYBERSENTINEL — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your real values
# ================================================================

# ── BRIGHT DATA (https://brightdata.com/cp/zones) ────────────────
# Create a "Residential" proxy zone → copy username + password
# Create a "SERP API" zone         → copy API key
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here
BRIGHT_DATA_USERNAME=brd-customer-XXXXXXXX-zone-XXXXXXXX
BRIGHT_DATA_PASSWORD=your_bright_data_zone_password_here

# ── OPENAI (https://platform.openai.com/api-keys) ────────────────
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o

# ── DATABASE ─────────────────────────────────────────────────────
# Local MongoDB (default — works out of the box if MongoDB is installed)
MONGODB_URI=mongodb://localhost:27017/cybersentinel

# Local Redis (default — works if Redis is installed)
REDIS_URL=redis://localhost:6379

# ── TELEGRAM ALERTS (optional) ───────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Add bot to a group → get chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=-1001234567890

# ── APP ──────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-any-long-random-string-abc123xyz
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
